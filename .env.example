# Required for wagmi/rainbowkit wallet connections inside tx-flow.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Optional network selector for tx-flow config (mainnet | testnet)
NEXT_PUBLIC_TXFLOW_NETWORK=testnet

# Enable testnet mode.
NEXT_PUBLIC_APP_ENV=testnet

# Server-only Spectrum RPC endpoint. Do NOT expose this publicly.
# Example shape: https://<spectrum-endpoint>/<api-key>/mezo/testnet/
SPECTRUM_MEZO_TESTNET_RPC_HTTP=

# Server secret used to sign short-lived RPC session tokens (10 minutes).
# Must be at least 32 characters.
SPECTRUM_RPC_SESSION_SECRET=

# Server-side RPC proxy rate limit (requests per second, per client IP bucket).
# Defaults to 10 if unset.
SPECTRUM_RPC_RPS_LIMIT=10
