# Required for wagmi/rainbowkit wallet connections inside tx-flow.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Optional network selector for tx-flow config (mainnet | testnet)
NEXT_PUBLIC_TXFLOW_NETWORK=testnet

# Use a Spectrum Nodes dashboard endpoint as the primary Mezo testnet RPC.
# Example shape: https://<spectrum-endpoint>/<api-key>/mezo/testnet/
NEXT_PUBLIC_APP_ENV=testnet
NEXT_PUBLIC_SPECTRUM_MEZO_TESTNET_RPC_HTTP=
